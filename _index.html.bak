            <!-- 连接线SVG -->
            <svg id="branch-lines" style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:1;"></svg>
            <script>
                function drawBranchLines() {
                    var svg = document.getElementById('branch-lines');
                    if (!svg) return;
                    
                    // 清空现有线条
                    svg.innerHTML = '';
                    
                    // 获取HQ卡片和分公司卡片
                    var hqCard = document.querySelector('.branch-hq-wrapper .branch-card');
                    var branchCards = document.querySelectorAll('.branches-grid .branch-card');
                    
                    if (!hqCard || branchCards.length === 0) return;
                    
                    // 获取section的位置（用于计算相对位置）
                    var section = document.getElementById('branches');
                    var sectionRect = section.getBoundingClientRect();
                    
                    // HQ卡片底部中心点
                    var hqRect = hqCard.getBoundingClientRect();
                    var hqX = hqRect.left + hqRect.width / 2 - sectionRect.left;
                    var hqY = hqRect.bottom - sectionRect.top;
                    
                    // 为每个分公司绘制连接线
                    branchCards.forEach(function(card) {
                        var cardRect = card.getBoundingClientRect();
                        var cardX = cardRect.left + cardRect.width / 2 - sectionRect.left;
                        var cardY = cardRect.top - sectionRect.top;
                        
                        // 创建线条
                        var line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
                        line.setAttribute('x1', hqX);
                        line.setAttribute('y1', hqY);
                        line.setAttribute('x2', cardX);
                        line.setAttribute('y2', cardY);
                        line.setAttribute('stroke', '#d4a843');
                        line.setAttribute('stroke-width', '2');
                        line.setAttribute('stroke-dasharray', '5,5');
                        line.setAttribute('opacity', '0.6');
                        
                        svg.appendChild(line);
                    });
                }
                
                // 页面加载和窗口大小改变时重新绘制
                window.addEventListener('load', drawBranchLines);
                window.addEventListener('resize', drawBranchLines);
                
                // 延迟执行以确保布局完成
                setTimeout(drawBranchLines, 500);
            </script>
        </div>
    </section>

