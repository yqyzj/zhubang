# ============================================================
# 湖南筑邦官网 — 性能 / 缓存 / 安全 策略
# 适用于 Apache（若主机为 Nginx，请将等价规则写入 Nginx 配置）
# 所有指令均包裹在 <IfModule> 中，模块缺失时自动忽略，不会报错。
# ============================================================

# 关闭目录列表（安全）
Options -Indexes

# ------- 浏览器缓存：静态资源长缓存（文件名即版本，可放心 immutable） -------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                      "access plus 1 year"
    ExpiresByType application/javascript        "access plus 1 year"
    ExpiresByType application/json              "access plus 1 week"
    ExpiresByType image/webp                 "access plus 1 year"
    ExpiresByType image/png                  "access plus 1 year"
    ExpiresByType image/jpeg                 "access plus 1 year"
    ExpiresByType image/gif                  "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType font/woff                 "access plus 1 year"
    # HTML 短缓存：内容更新后很快生效
    ExpiresByType text/html                  "access plus 1 hour"
</IfModule>

# ------- Cache-Control 响应头（与上面互补） -------
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|webp|png|jpe?g|gif|svg|woff2?|ttf|ico)$">
        Header set Cache-Control "max-age=31536000, public, immutable"
    </FilesMatch>
    <FilesMatch "\.html?$">
        Header set Cache-Control "max-age=3600, public, must-revalidate"
    </FilesMatch>

    # 基础安全响应头
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

    # 关闭 ETag，配合多节点/CDN 更稳定
    Header unset ETag
</IfModule>
FileETag None

# ------- 传输压缩（Gzip / Brotli） -------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json application/xml image/svg+xml
</IfModule>
